{
  "name": "@mrdwarf7/ft-pipeline",
  "exports": "./src/main.ts",
  "version": "0.1.0",
  "tasks": {
    "start": "deno run --allow-all src/main.ts",
    "dev": "deno run --watch --allow-all src/main.ts",
    "dev:migrate": "deno run --allow-all src/main.ts migrate",
    "dev:merge": "deno run --allow-all src/main.ts merge",
    "dev:full": "deno run --allow-all src/main.ts full",
    "ch:fmt": "deno fmt",
    "ch:check": "deno check src/main.ts",
    "ch:lint": "deno lint",
    "ch:all": "deno fmt && deno check src/main.ts && deno lint",
    "build": "deno compile --allow-all -o dist/ft-pipeline src/main.ts",
    "uat:build": "FT_PIPELINE_ENV=development deno task build",
    "uat": "FT_PIPELINE_ENV=development deno task uat:build && FT_PIPELINE_ENV=development ./dist/ft-pipeline",
    "release:build": "FT_PIPELINE_ENV=production deno task build",
    "release": "FT_PIPELINE_ENV=production deno task release:build && FT_PIPELINE_ENV=production ./dist/ft-pipeline"
  },
  "imports": {
    "@db/sqlite": "jsr:@db/sqlite@^0.13.0",
    "@std/async": "jsr:@std/async@^1.4.0",
    "@std/io": "jsr:@std/io@^0.225.3",
    "@std/path": "jsr:@std/path@1",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/cli": "jsr:@std/cli@1",
    "@std/log": "jsr:@std/log@0.224",
    "zod": "npm:zod@^4.4.3"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "all",
        "eqeqeq",
        "no-await-in-loop",
        "no-console",
        "no-throw-literal",
        "default-param-last",
        "no-useless-rename",
        "no-sync-fn-in-async-fn",
        "no-sparse-arrays"
      ]
    }
  },
  "nodeModulesDir": "auto",
  "unstable": [
    "ffi"
  ]
}
