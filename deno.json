{
  "exports": "./main.ts",
  "name": "@mrdwarf7/ft-pipeline",
  "version": "0.1.0",
  "tasks": {
    "start": "deno run --allow-all main.ts",
    "dev": "deno run --watch --allow-all main.ts",
    "build": "deno compile --allow-all -o ft-pipeline main.ts",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "check": "deno check main.ts",
    "migrate": "deno run --allow-all main.ts migrate",
    "merge": "deno run --allow-all main.ts merge",
    "full": "deno run --allow-all main.ts full"
  },
  "imports": {
    "@std/path": "jsr:@std/path@1",
    "@std/fs": "jsr:@std/fs@1",
    "@std/cli": "jsr:@std/cli@1",
    "@std/log": "jsr:@std/log@0.224"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "all",
        "eqeqeq",
        "no-await-in-loop",
        "no-console",
        "no-throw-literal",
        "default-param-last",
        "no-useless-rename",
        "no-sync-fn-in-async-fn",
        "no-sparse-arrays"
      ]
    }
  },
  "nodeModulesDir": "none",
  "unstable": [
    "ffi"
  ]
}
